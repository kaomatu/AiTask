{
  "expo": {
    "name": "AiTask",
    "slug": "smartphone-app-byExpo",
    "owner": "kaomatu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon/Frame 3.png",
    "scheme": "smartphoneappbyexpo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.k26008kk.aitask"
    },
    "android": {
      "package": "com.k26008kk.taskapp",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon/Frame 3.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "web": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/icon/Frame 3.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "cameraPermission": "タスクに添付する写真を撮影するためにカメラを使用します。",
          "photosPermission": "タスクに添付する写真を選択するためにフォトライブラリを使用します。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f0d5797-038f-4c08-a83a-484cef464257"
      }
    }
  }
}
